# ==============================
# SERVER
# ==============================
PORT=5000
NODE_ENV=development

# ==============================
# DATABASE (MongoDB Atlas)
# Connection string lấy từ: Atlas Dashboard > Connect > Drivers
# Thay <password> và <cluster-address> bằng thông tin thật
# ==============================
MONGO_URI=mongodb+srv://manhcuongcontact_db_user:cuong3011@cluster0.<your-cluster>.mongodb.net/phongkham?retryWrites=true&w=majority

# ==============================
# JWT AUTH
# ==============================
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_at_least_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==============================
# CORS (Frontend URL)
# ==============================
FRONTEND_URL=http://localhost:3000

# ==============================
# EMAIL (Brevo Transactional API)
# Lấy tại: https://app.brevo.com/settings/keys/api
# ==============================
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxx

# ==============================
# AI CHATBOT (Google Gemini)
# Lấy tại: https://aistudio.google.com/app/apikey
# ==============================
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxx
